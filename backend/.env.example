DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTE=30
BACKEND_PUBLIC_URL=https://api.your-domain.com
CORS_ORIGINS=https://your-frontend-domain.com
SQL_ECHO=false
EMAIL_VERIFICATION_ENABLED=false
AUTO_VERIFY_EMAILS=true

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=replace-with-a-strong-password

MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=Printia <your-email@example.com>
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

KIOSK_DEFAULT_EMAIL=kiosk@example.com
KIOSK_DEFAULT_PASSWORD=replace-with-a-strong-password
