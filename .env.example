# Backend
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
SECRET_KEY=replace-with-a-long-random-secret
BACKEND_PUBLIC_URL=https://api.your-domain.com
CORS_ORIGINS=https://your-frontend-domain.com
EMAIL_VERIFICATION_ENABLED=false
AUTO_VERIFY_EMAILS=true
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=replace-with-a-strong-password
DEFAULT_KIOSK_USERNAME=kiosk
DEFAULT_KIOSK_EMAIL=kiosk@example.com
DEFAULT_KIOSK_PASSWORD=replace-with-a-strong-password
DEFAULT_USER_USERNAME=user
DEFAULT_USER_EMAIL=user@example.com
DEFAULT_USER_PASSWORD=replace-with-a-strong-password

# Frontend
VITE_API_URL=https://api.your-domain.com
